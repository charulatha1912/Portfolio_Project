# .env.example - Copy this to .env and fill in your values
# Never commit the actual .env file to Git!

# Neon PostgreSQL connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgresql://username:password@hostname/dbname?sslmode=require

# Your Vercel frontend URL (used for CORS)
# During development: http://localhost:5173
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Flask debug mode
# Set to False in production!
FLASK_DEBUG=True
